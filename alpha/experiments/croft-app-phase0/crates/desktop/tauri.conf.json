{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pond",
  "version": "0.0.0",
  "identifier": "com.croftc.experiments.pond",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:8080"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "pond",
        "width": 480,
        "height": 900,
        "minWidth": 360,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
