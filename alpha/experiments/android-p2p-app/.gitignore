# Rust build artifacts (the cdylib is ~300MB; never commit it)
core/target/
**/*.rs.bk

# Native libraries are produced by cargo-ndk into jniLibs at build time
android/app/src/main/jniLibs/**/*.so

# Gradle / Android build outputs
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
android/captures/
*.iml

