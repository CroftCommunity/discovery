# Pinned versions for the box (guardrail: reproducible bootstrap).
# Sourced by bootstrap.sh. Bump deliberately, never float.
LITESTREAM_VERSION=0.3.13
RCLONE_VERSION=1.66.0
# Caddy comes from the official apt repo (packagecloud); pinned by apt at the
# repo's current stable. Debian's own caddy is too old for on-demand TLS.
CADDY_SOURCE=official-apt
# Base image expectation.
EXPECTED_OS=debian-12
# The stub artifact needs python3 on the box; real binaries do not.
PYTHON_MIN=3.11
