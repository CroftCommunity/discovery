# Copy to `.env` (git-ignored) and fill in. NEVER commit real credentials.
#
# Use a DEDICATED THROWAWAY test account, never a personal/corporate identity.
# Records published by this experiment are PUBLIC. Use innocuous content only
# and run `cleanup` afterwards.

# Your test account handle, e.g. yourtest.bsky.social
ATPROTO_HANDLE=

# An APP PASSWORD (Settings → Privacy & Security → App Passwords), NOT your
# main account password. App-password auth is the headless-friendly path this
# experiment uses (see README: full OAuth is infeasible in a headless container).
ATPROTO_APP_PASSWORD=

# Optional overrides:
# ATPROTO_HOST=https://bsky.social
# JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe
